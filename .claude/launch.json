{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "PHP Dev Server",
      "runtimeExecutable": "php",
      "runtimeArgs": ["-S", "localhost:8000"],
      "port": 8000
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "3000"],
      "port": 3000
    },
    {
      "name": "Node serve (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "5000"],
      "port": 5000
    }
  ]
}
